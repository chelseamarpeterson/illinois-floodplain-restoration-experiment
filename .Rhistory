types = c("Palustrine","Riverine")
n.t = length(types)
rules = sort(unique(il.pal.riv.df$JD.Basis))
n.r = length(rules)
counties = sort(unique(il.pal.riv.df$County))
n.c = length(counties)
for (j in 1:n.t) {
type.j = types[j]
df.type.j = subset(il.pal.riv.df, il.pal.riv.df$Cowardin.Category == type.j)
path.type.j = paste("Clean_County_Data", type.j, sep="/")
type.county.df.all = data.frame(matrix(nrow=n.c, ncol=0))
type.county.df.all$County = counties
for (i in 1:n.r) {
rule.i = rules[i]
df.type.j.rule.i = subset(df.type.j, df.type.j$JD.Basis == rule.i)
type.rule.county.df = df.type.j.rule.i %>%
group_by(County) %>%
summarize(percent_wotus = sum(WOTUS_TF)/sum(ones)*100,
percent_nonwotus = 100-sum(WOTUS_TF)/sum(ones)*100,
count_wotus = sum(WOTUS_TF),
count_nonwotus = sum(ones) - sum(WOTUS_TF),
jd_count = sum(ones))
if (rule.i == "1986/88") {
write.csv(type.rule.county.df, paste(path.type.j, "_County_Summaries_1986_88.csv",sep=""), row.names=F)
} else {
write.csv(type.rule.county.df, paste(path.type.j, "_County_Summaries_",rule.i,".csv",sep=""), row.names=F)
}
# join county data to frame by rule
colnames(type.rule.county.df) = c("County",paste(rule.i, colnames(type.rule.county.df)[2:6], sep="_"))
type.county.df.all = left_join(type.county.df.all, type.rule.county.df, by="County")
}
# write all  wetland point and county data to one file by type
write.csv(type.county.df.all, paste("Clean_County_Data/",type.j,"_County_Summaries_All_Rules.csv",sep=""), row.names=F)
}
