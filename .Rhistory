stock.hdi.df$variable.label[stock.hdi.df$variable.label == "Coarse woody debris (>= 7.6 cm)"] = "Coarse woody debris\n(>= 7.6 cm)"
p.stock.hdi.comp = ggplot(stock.hdi.df,
