"Jurisdictional impoundment",
"RPW tributary",
"Wetland w/ CSC to RPW",
"Wetland w/ CSC to TNW",
"Jurisdictional intrastate lake or pond",
"Artificial lake or pond (excluded)",
"Waste treatment system (excluded)",
"Irrigated wetland (excluded)",
"Ditches (excluded)",
"Artificial pool (excluded)",
"Construction activity (excluded)",
"Erosional features (excluded)",
"Prior converted cropland (excluded)")
n.r = length(reasons.long)
am2023.il.df$Reason = 0
for (i in 1:n.r) { am2023.il.df$Reason[am2023.il.df$Resource.Type.Description == reasons.long[i]] = reasons.short[i] }
am2023.il.df[which(am2023.il.df$Reason == 0),"Resource.Type.Description"]
#sort(unique(am2023.il.df$Reason))
am2023.il.reason.sum = am2023.il.df[am2023.il.df$WOTUS_TF == 0,] %>%
group_by(Cowardin.Category, Reason) %>%
summarize(count = sum(ones),
unpro.count = sum(ones*(1-protected.county)))
ggplot(am2023.il.reason.sum,
aes(y=Reason, x=count)) +
geom_bar(stat="identity") +
labs(x="AJD count", y="Reason for lack of federal jurisdiction") +
facet_wrap(.~Cowardin.Category,
scales="free")
ggplot(am2023.il.reason.sum,
aes(y=Reason, x=count)) +
geom_bar(stat="identity") +
labs(x="AJD count", y="Reason for lack of federal jurisdiction") +
facet_wrap(.~Cowardin.Category,
scales="free")
am2023.il.df$Wetland.Type = 0
full.codes = sort(unique(am2023.il.df$Cowardin.Code))
for (i in 1:length(full.codes)) {
full.code = full.codes[i]
code.id = which(am2023.il.df$Cowardin.Code == full.code)
if (full.code %in% c("L1","L1OW","L1UB")) {
simple.code = "Limnetic lake"
} else if (full.code %in% c("L2","L2OW")) {
simple.code = "Littoral lake"
} else if (full.code %in% c("PAB","PAB6","PUB","POW")) {
simple.code = "Freshwater pond"
} else if (full.code %in% c("PSS","PFO")) {
simple.code = "Freshwater forested/scrub-shrub"
} else if (full.code %in% c("PEM")) {
simple.code = "Freshwater emergent"
} else if (full.code %in% c("R2","R2RS")) {
simple.code = "Lower perennial"
} else if (full.code %in% c("R3","R3RS")) {
simple.code = "Upper perennial"
} else if (full.code %in% c("R4","R4SB")) {
simple.code = "Intermittent"
} else if (full.code %in% c("R5","R5RB","R5UB")) {
simple.code = "Unknown perennial"
} else if (full.code %in% c("R6")) {
simple.code = "Ephemeral"
} else if (full.code %in% c("RP1EM")) {
simple.code = "Lotic"
} else if (full.code %in% c("RP2","RP2EM")) {
simple.code = "Lentic"
} else if (full.code == "RP") {
simple.code = "Unknown riparian"
}
am2023.il.df$Wetland.Type[code.id] = simple.code
}
sort(unique(am2023.il.df$Wetland.Type))
am2023.il.type.sum = am2023.il.df %>%
group_by(Cowardin.Category, Wetland.Type) %>%
summarize(total.jd.count = sum(ones),
total.percent.wotus = sum(WOTUS_TF)/sum(ones)*100,
total.percent.nonwotus = 100-sum(WOTUS_TF)/sum(ones)*100,
total.count.wotus = sum(WOTUS_TF),
total.count.nonwotus = sum(ones) - sum(WOTUS_TF),
unpro.jd.count = sum(ones*(1-protected.county)),
unpro.percent.wotus = sum(WOTUS_TF*(1-protected.county))/sum(ones*(1-protected.county))*100,
unpro.percent.nonwotus = 100-sum(WOTUS_TF*(1-protected.county))/sum(ones*(1-protected.county))*100,
unpro.count.wotus = sum(WOTUS_TF*(1-protected.county)),
unpro.count.nonwotus = sum(ones*(1-protected.county))-sum(WOTUS_TF*(1-protected.county)))
type.melt = melt(am2023.il.type.sum, id.var=c("Cowardin.Category","Wetland.Type"))
state.type.percent = type.melt[type.melt$variable %in% state.percent.vars,]
state.type.percent$wotus.label = rep(0, nrow(state.type.percent))
for (i in 1:2) { state.type.percent$wotus.label[state.type.percent$variable == state.percent.vars[i]] = labels[i] }
state.type.percent$scope = "Entire state"
View(am2023.il.type.sum)
type.melt = melt(am2023.il.type.sum, id.var=c("Cowardin.Category","Wetland.Type"))
state.percent.vars
am2023.il.type.sum = am2023.il.df %>%
group_by(Cowardin.Category, Wetland.Type) %>%
summarize(total_jd_count = sum(ones),
total_percent_wotus = sum(WOTUS_TF)/sum(ones)*100,
total_percent_nonwotus = 100-sum(WOTUS_TF)/sum(ones)*100,
total_count_wotus = sum(WOTUS_TF),
total_count_nonwotus = sum(ones) - sum(WOTUS_TF),
unpro_jd_count = sum(ones*(1-protected.county)),
unpro_percent_wotus = sum(WOTUS_TF*(1-protected.county))/sum(ones*(1-protected.county))*100,
unpro_percent_nonwotus = 100-sum(WOTUS_TF*(1-protected.county))/sum(ones*(1-protected.county))*100,
unpro_count_wotus = sum(WOTUS_TF*(1-protected.county)),
unpro_count_nonwotus = sum(ones*(1-protected.county))-sum(WOTUS_TF*(1-protected.county)))
type.melt = melt(am2023.il.type.sum, id.var=c("Cowardin.Category","Wetland.Type"))
state.type.percent = type.melt[type.melt$variable %in% state.percent.vars,]
state.type.percent$wotus.label = 0
for (i in 1:2) { state.type.percent$wotus.label[state.type.percent$variable == state.percent.vars[i]] = labels[i] }
state.type.percent$scope = "Entire state"
state.type.percent$type = "Percents"
county.type.percent = type.melt[type.melt$variable %in% county.percent.vars,]
county.type.percent$wotus.label = 0
for (i in 1:2) { county.type.percent$wotus.label[county.type.percent$variable == county.percent.vars[i]] = labels[i] }
county.type.percent$scope = "Outside counties with ordinances"
county.type.percent$type = "Percents"
percent.df = rbind(state.type.percent,county.type.percent)
ggplot(percent.df,
aes(y=Wetland.Type, x=value, fill=wotus.label)) +
geom_bar(stat="identity") +
scale_fill_manual(values = c("WOTUS"="darkblue","Non-WOTUS"="lightblue")) +
facet_grid(Cowardin.Category~scope, scales="free_y") +
labs(y="WOTUS Rule",x="Percent (%)",
fill="Jurisdictional determination")
